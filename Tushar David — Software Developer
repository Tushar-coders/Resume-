@charset "utf-8";

:root { --ink: #101418; --paper: #F7F5F0; --paper-raised: #FFFFFF; --line: #DAD5C8; --signal: #C8542C; --signal-dim: #E8D9CC; --mono: #5B5B52; }

* { box-sizing: border-box; margin: 0px; padding: 0px; }

html { scroll-behavior: smooth; }

body { background: var(--paper); color: var(--ink); font-family: Inter, sans-serif; line-height: 1.5; -webkit-font-smoothing: antialiased; }

a { color: var(--signal); text-decoration: none; }

a:hover { text-decoration: underline; }

.wrap { max-width: 760px; margin: 0px auto; padding: 0px 24px; }

header.hero { border-bottom: 1px solid var(--line); padding: 64px 0px 40px; }

.eyebrow { font-family: "IBM Plex Mono", monospace; font-size: 12.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--signal); margin-bottom: 18px; display: flex; align-items: center; gap: 10px; }

.eyebrow::before { content: ""; width: 8px; height: 8px; background: var(--signal); display: inline-block; border-radius: 1px; }

h1 { font-family: "Space Grotesk", sans-serif; font-weight: 700; font-size: clamp(38px, 7vw, 56px); letter-spacing: -0.02em; line-height: 1.02; }

.role { font-family: "IBM Plex Mono", monospace; font-size: 16px; color: var(--mono); margin-top: 10px; }

.contact-row { margin-top: 28px; display: flex; flex-wrap: wrap; gap: 18px; font-family: "IBM Plex Mono", monospace; font-size: 13.5px; }

.contact-row a { color: var(--ink); border-bottom: 1px solid var(--line); }

.contact-row a:hover { border-color: var(--signal); color: var(--signal); text-decoration: none; }

.btn-row { margin-top: 26px; display: flex; gap: 12px; flex-wrap: wrap; }

.btn { font-family: "IBM Plex Mono", monospace; font-size: 13px; padding: 10px 18px; border: 1px solid var(--ink); border-radius: 3px; color: var(--ink); transition: background 0.15s, color 0.15s; }

.btn:hover { background: var(--ink); color: var(--paper); text-decoration: none; }

.btn.primary { background: var(--signal); border-color: var(--signal); color: rgb(255, 255, 255); }

.btn.primary:hover { background: rgb(168, 66, 31); border-color: rgb(168, 66, 31); color: rgb(255, 255, 255); }

section { padding: 48px 0px; }

section + section { border-top: 1px solid var(--line); }

.section-head { display: flex; align-items: baseline; gap: 14px; margin-bottom: 28px; }

.section-num { font-family: "IBM Plex Mono", monospace; font-size: 13px; color: var(--signal); }

h2 { font-family: "Space Grotesk", sans-serif; font-size: 22px; font-weight: 600; letter-spacing: -0.01em; }

p.lede { max-width: 620px; color: rgb(44, 44, 40); font-size: 16px; }

.skill-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 22px 32px; }

.skill-block dt { font-family: "IBM Plex Mono", monospace; font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mono); margin-bottom: 6px; }

.skill-block dd { font-size: 14.5px; }

.entry { display: grid; grid-template-columns: 120px 1fr; gap: 20px; padding: 22px 0px; border-top: 1px solid var(--line); }

.entry:first-of-type { border-top-width: medium; border-top-style: none; border-top-color: currentcolor; padding-top: 0px; }

.entry-tag { font-family: "IBM Plex Mono", monospace; font-size: 12px; color: var(--mono); padding-top: 3px; }

.entry h3 { font-family: "Space Grotesk", sans-serif; font-size: 17px; font-weight: 600; margin-bottom: 4px; }

.entry .sub { font-size: 13.5px; color: var(--mono); margin-bottom: 10px; font-style: italic; }

.entry ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }

.entry li { font-size: 14.5px; padding-left: 16px; position: relative; color: rgb(38, 38, 34); }

.entry li::before { content: "—"; position: absolute; left: 0px; color: var(--signal); }

@media (max-width: 560px) {
  .entry { grid-template-columns: 1fr; }
  .entry-tag { padding-top: 0px; }
}

.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }

@media (max-width: 560px) {
  .two-col { grid-template-columns: 1fr; }
}

.mini-list { list-style: none; }

.mini-list li { padding: 10px 0px; border-top: 1px solid var(--line); font-size: 14.5px; }

.mini-list li:first-child { border-top-width: medium; border-top-style: none; border-top-color: currentcolor; }

.mini-list .deg { font-weight: 600; }

.mini-list .school { color: var(--mono); font-size: 13px; display: block; margin-top: 2px; }

footer { padding: 36px 0px 60px; font-family: "IBM Plex Mono", monospace; font-size: 12.5px; color: var(--mono); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
